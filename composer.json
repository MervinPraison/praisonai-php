{
    "name": "mervinpraison/praisonai",
    "description": "PraisonAI PHP AI Agents Framework - Build AI agents and multi-agent workflows in PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mervin Praison"
        }
    ],
    "keywords": [
        "ai",
        "agents",
        "ai-agents",
        "llm",
        "openai",
        "php-ai",
        "php-ai-agents",
        "praisonai",
        "ai-framework",
        "multi-agent"
    ],
    "homepage": "https://docs.praison.ai",
    "require": {
        "php": "^8.2",
        "openai-php/client": "^0.10",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PraisonAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PraisonAI\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}